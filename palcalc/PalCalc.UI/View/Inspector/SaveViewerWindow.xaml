<adonisControls:AdonisWindow x:Class="PalCalc.UI.View.Inspector.SaveViewerWindow"
                             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                             xmlns:local="clr-namespace:PalCalc.UI.View.Inspector"
                             xmlns:sv="clr-namespace:PalCalc.UI.View.Inspector.Search"
                             xmlns:iv="clr-namespace:PalCalc.UI.View.Inspector"
                             xmlns:v="clr-namespace:PalCalc.UI.View"
                             xmlns:vu="clr-namespace:PalCalc.UI.View.Utils"
                             xmlns:vp="clr-namespace:PalCalc.UI.View.Pal"
                             xmlns:svm="clr-namespace:PalCalc.UI.ViewModel.Inspector"
                             xmlns:ivm="clr-namespace:PalCalc.UI.ViewModel.Inspector"
                             xmlns:sm="clr-namespace:PalCalc.UI.ViewModel.Inspector.Search"
                             xmlns:sgvm="clr-namespace:PalCalc.UI.ViewModel.Inspector.Search.Grid"
                             xmlns:dvm="clr-namespace:PalCalc.UI.ViewModel.Inspector.Details"
                             xmlns:mvm="clr-namespace:PalCalc.UI.ViewModel.Mapped"
                             xmlns:vm="clr-namespace:PalCalc.UI.ViewModel"
                             xmlns:dnkc="clr-namespace:DotNetKit.Windows.Controls;assembly=DotNetKit.Wpf.AutoCompleteComboBox"
                             xmlns:itl="clr-namespace:PalCalc.UI.Localization"
                             xmlns:c="clr-namespace:PalCalc.UI.ViewModel.Converters"
                             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
                             xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
                             xmlns:adonisUi="clr-namespace:AdonisUI;assembly=AdonisUI"
                             xmlns:adonisControls="clr-namespace:AdonisUI.Controls;assembly=AdonisUI"
                             xmlns:adonisConverters="clr-namespace:AdonisUI.Converters;assembly=AdonisUI"
                             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
                             mc:Ignorable="d"
                             WindowStartupLocation="CenterScreen"
                             d:DataContext="{x:Static svm:SaveViewerWindowViewModel.DesignerInstance}"
                             IconVisibility="Collapsed"
                             Title="{Binding WindowTitle.Value}"
                             Height="900" Width="1400"
                             MinHeight="600" MinWidth="1000">
    <adonisControls:AdonisWindow.Resources>
        <c:ValueVisibilityConverter x:Key="VVC" />
        <c:ValueBoolConverter x:Key="VBC" />

        <!-- Tweaked version of the default Tab control to adjust spacing -->
        <Style TargetType="TabControl" BasedOn="{StaticResource {x:Type TabControl}}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TabPanel x:Name="HeaderPanel"
                                      Grid.Row="0"
                                      Panel.ZIndex="1"
                                      IsItemsHost="True"
                                      KeyboardNavigation.TabIndex="1"
                                      Background="{x:Null}" />

                            <Border x:Name="Border"
                                    Grid.Row="1"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    KeyboardNavigation.TabNavigation="Local"
                                    KeyboardNavigation.DirectionalNavigation="Contained"
                                    KeyboardNavigation.TabIndex="2">
                                <Border.CornerRadius>
                                    <MultiBinding Converter="{x:Static adonisConverters:ValuesToCornerRadiusConverter.Instance}">
                                        <Binding Source="0"/>
                                        <Binding Path="(adonisExtensions:CornerRadiusExtension.CornerRadius).TopRight" RelativeSource="{RelativeSource TemplatedParent}"/>
                                        <Binding Path="(adonisExtensions:CornerRadiusExtension.CornerRadius).BottomRight" RelativeSource="{RelativeSource TemplatedParent}"/>
                                        <Binding Path="(adonisExtensions:CornerRadiusExtension.CornerRadius).BottomLeft" RelativeSource="{RelativeSource TemplatedParent}"/>
                                    </MultiBinding>
                                </Border.CornerRadius>

                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  Margin="0,4,0,0"
                                                  ContentSource="SelectedContent" />
                            </Border>

                            <Border x:Name="SelectedItemHighlight"
                                    Grid.Row="1"
                                    Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1HighlightBrush}}"
                                    Margin="{TemplateBinding BorderThickness}"
                                    VerticalAlignment="Top"
                                    Height="4">
                                <Border.CornerRadius>
                                    <MultiBinding Converter="{x:Static adonisConverters:ValuesToCornerRadiusConverter.Instance}">
                                        <Binding Source="0"/>
                                        <Binding Path="(adonisExtensions:CornerRadiusExtension.CornerRadius).TopRight" RelativeSource="{RelativeSource TemplatedParent}"/>
                                        <Binding Source="0"/>
                                        <Binding Source="0"/>
                                    </MultiBinding>
                                </Border.CornerRadius>
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding Path=(adonisExtensions:LayerExtension.ComputedLayer), RelativeSource={RelativeSource Self}}" Value="2">
                                <Setter Property="Background" TargetName="SelectedItemHighlight" Value="{DynamicResource {x:Static adonisUi:Brushes.Layer2HighlightBrush}}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Path=(adonisExtensions:LayerExtension.ComputedLayer), RelativeSource={RelativeSource Self}}" Value="3">
                                <Setter Property="Background" TargetName="SelectedItemHighlight" Value="{DynamicResource {x:Static adonisUi:Brushes.Layer3HighlightBrush}}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Path=(adonisExtensions:LayerExtension.ComputedLayer), RelativeSource={RelativeSource Self}}" Value="4">
                                <Setter Property="Background" TargetName="SelectedItemHighlight" Value="{DynamicResource {x:Static adonisUi:Brushes.Layer4HighlightBrush}}"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </adonisControls:AdonisWindow.Resources>

    <Window.Style>
        <Style TargetType="Window" BasedOn="{StaticResource {x:Type Window}}" />
    </Window.Style>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top" Background="{DynamicResource {x:Static adonisUi:Brushes.Layer2BackgroundBrush}}">
            <MenuItem Header="{itl:LocalizedText LC_LANGUAGE}" ItemsSource="{Binding Locales}" Padding="5">
                <MenuItem.ItemContainerStyle>
                    <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                        <Setter Property="Header" Value="{Binding Label}" />
                        <Setter Property="IsCheckable" Value="True" />
                        <Setter Property="IsChecked" Value="{Binding IsSelected}" />
                        <Setter Property="Command" Value="{Binding SelectCommand}" />
                    </Style>
                </MenuItem.ItemContainerStyle>
            </MenuItem>
        </Menu>

        <!-- Top Bar: Save Selector -->
        <Border DockPanel.Dock="Top" 
                Background="{DynamicResource {x:Static adonisUi:Brushes.Layer2BackgroundBrush}}" 
                Padding="8,6" 
                Margin="0,0,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" vu:StackPanelExtensions.Spacing="10">
                    <Label Content="{itl:LocalizedText LC_SAVE_FILE}" VerticalAlignment="Center" FontWeight="Bold" />
                    <ComboBox ItemsSource="{Binding AvailableSaves}" 
                              SelectedItem="{Binding SelectedSave}"
                              Width="350"
                              DisplayMemberPath="Label"
                              IsSynchronizedWithCurrentItem="True">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                <Setter Property="IsEditable" Value="False" />
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" vu:StackPanelExtensions.Spacing="5">
                    <Button Content="Reload Save" 
                            Command="{Binding RefreshCommand}" 
                            Width="100" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="220"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="300" MinWidth="250" MaxWidth="500"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Container Tree + Search Settings -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search Settings -->
                <Expander Header="{itl:LocalizedText LC_SAVESEARCH_GRP_SEARCH_SETTINGS}" 
                          Grid.Row="0" 
                          IsExpanded="True" 
                          adonisExtensions:LayerExtension.IncreaseLayer="True">
                    <StackPanel Orientation="Vertical">
                        <vu:SpacedWrapPanel Margin="5" HorizontalSpacing="8" VerticalSpacing="6">

                            <StackPanel Orientation="Vertical">
                                <Label Content="{itl:LocalizedText LC_COMMON_PAL}" Style="{StaticResource ComboBoxAlignedLabelStyle}" />
                                <dnkc:AutoCompleteComboBox Width="180" 
                                                           ItemsSource="{x:Static mvm:PalViewModel.All}" 
                                                           SelectedValue="{Binding Search.SearchSettings.SearchedPal}" 
                                                           TextSearch.TextPath="Label.Value">
                                    <dnkc:AutoCompleteComboBox.ItemTemplate>
                                        <DataTemplate DataType="mvm:PalViewModel">
                                            <TextBlock Text="{Binding Label.Value}" />
                                        </DataTemplate>
                                    </dnkc:AutoCompleteComboBox.ItemTemplate>
                                </dnkc:AutoCompleteComboBox>
                            </StackPanel>

                            <StackPanel Orientation="Vertical">
                                <Label Content="{itl:LocalizedText LC_COMMON_GENDER}" Style="{StaticResource ComboBoxAlignedLabelStyle}" />
                                <ComboBox ItemsSource="{Binding Search.SearchSettings.GenderOptions}" 
                                          SelectedItem="{Binding Search.SearchSettings.SearchedGender}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type sm:GenderOption}">
                                            <TextBlock Text="{Binding Label.Value}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Orientation="Vertical">
                                <StackPanel.Resources>
                                    <Style TargetType="dnkc:AutoCompleteComboBox" BasedOn="{StaticResource {x:Type dnkc:AutoCompleteComboBox}}">
                                        <Setter Property="Margin" Value="0,0,8,4" />
                                        <Setter Property="Width" Value="140" />
                                    </Style>
                                </StackPanel.Resources>
                                <Label Content="{itl:LocalizedText LC_COMMON_TRAITS}" Style="{StaticResource ComboBoxAlignedLabelStyle}" />
                                <WrapPanel Orientation="Horizontal">
                                    <WrapPanel.Resources>
                                        <DataTemplate x:Key="PassiveTemplate" DataType="{x:Type mvm:PassiveSkillViewModel}">
                                            <TextBlock Text="{Binding Name.Value}" />
                                        </DataTemplate>
                                    </WrapPanel.Resources>

                                    <dnkc:AutoCompleteComboBox ItemsSource="{x:Static mvm:PassiveSkillViewModel.All}" 
                                                               TextSearch.TextPath="Name.Value" 
                                                               SelectedValue="{Binding Search.SearchSettings.SearchedPassive1}" 
                                                               ItemTemplate="{StaticResource PassiveTemplate}" />
                                    <dnkc:AutoCompleteComboBox ItemsSource="{x:Static mvm:PassiveSkillViewModel.All}" 
                                                               TextSearch.TextPath="Name.Value" 
                                                               SelectedValue="{Binding Search.SearchSettings.SearchedPassive2}" 
                                                               ItemTemplate="{StaticResource PassiveTemplate}" />
                                    <dnkc:AutoCompleteComboBox ItemsSource="{x:Static mvm:PassiveSkillViewModel.All}" 
                                                               TextSearch.TextPath="Name.Value" 
                                                               SelectedValue="{Binding Search.SearchSettings.SearchedPassive3}" 
                                                               ItemTemplate="{StaticResource PassiveTemplate}" />
                                    <dnkc:AutoCompleteComboBox ItemsSource="{x:Static mvm:PassiveSkillViewModel.All}" 
                                                               TextSearch.TextPath="Name.Value" 
                                                               SelectedValue="{Binding Search.SearchSettings.SearchedPassive4}" 
                                                               ItemTemplate="{StaticResource PassiveTemplate}" />
                                </WrapPanel>
                            </StackPanel>

                            <StackPanel Orientation="Vertical">
                                <StackPanel.Resources>
                                    <Style TargetType="dnkc:AutoCompleteComboBox" BasedOn="{StaticResource {x:Type dnkc:AutoCompleteComboBox}}">
                                        <Setter Property="Margin" Value="0,0,8,4" />
                                        <Setter Property="Width" Value="140" />
                                    </Style>
                                </StackPanel.Resources>
                                <Label Content="{itl:LocalizedText Code=LC_COMMON_ATTACK_SKILLS}" Style="{StaticResource ComboBoxAlignedLabelStyle}" />
                                <WrapPanel Orientation="Horizontal">
                                    <WrapPanel.Resources>
                                        <DataTemplate x:Key="SkillTemplate" DataType="{x:Type mvm:PassiveSkillViewModel}">
                                            <TextBlock Text="{Binding Name.Value}" />
                                        </DataTemplate>
                                    </WrapPanel.Resources>

                                    <dnkc:AutoCompleteComboBox ItemsSource="{x:Static mvm:ActiveSkillViewModel.All}" 
                                                               TextSearch.TextPath="Name.Value" 
                                                               SelectedValue="{Binding Search.SearchSettings.SearchedSkill1}" 
                                                               ItemTemplate="{StaticResource SkillTemplate}" />
                                    <dnkc:AutoCompleteComboBox ItemsSource="{x:Static mvm:ActiveSkillViewModel.All}" 
                                                               TextSearch.TextPath="Name.Value" 
                                                               SelectedValue="{Binding Search.SearchSettings.SearchedSkill2}" 
                                                               ItemTemplate="{StaticResource SkillTemplate}" />
                                    <dnkc:AutoCompleteComboBox ItemsSource="{x:Static mvm:ActiveSkillViewModel.All}" 
                                                               TextSearch.TextPath="Name.Value" 
                                                               SelectedValue="{Binding Search.SearchSettings.SearchedSkill3}" 
                                                               ItemTemplate="{StaticResource SkillTemplate}" />
                                    <dnkc:AutoCompleteComboBox ItemsSource="{x:Static mvm:ActiveSkillViewModel.All}" 
                                                               TextSearch.TextPath="Name.Value" 
                                                               SelectedValue="{Binding Search.SearchSettings.SearchedSkill4}" 
                                                               ItemTemplate="{StaticResource SkillTemplate}" />
                                </WrapPanel>
                            </StackPanel>

                            <StackPanel Orientation="Vertical">
                                <ComboBox ItemsSource="{Binding Search.SearchSettings.IVFilterOptions}" 
                                          Width="Auto" 
                                          HorizontalAlignment="Left" 
                                          SelectedItem="{Binding Search.SearchSettings.IvFilterMode}" 
                                          Margin="0,0,0,4">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type sm:IVFilterModeOption}">
                                            <Label Content="{Binding Label.Value}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel.Resources>
                                        <Style TargetType="Label" BasedOn="{StaticResource {x:Type Label}}">
                                            <Setter Property="Padding" Value="2" />
                                            <Setter Property="Margin" Value="0,0,5,0" />
                                        </Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Margin" Value="0,0,12,0" />
                                        </Style>
                                    </StackPanel.Resources>

                                    <StackPanel Orientation="Horizontal">
                                        <Label Content="{itl:LocalizedText LC_COMMON_IV_HP}" />
                                        <vu:IntegerTextBox MinValue="0" MaxValue="100" Value="{Binding Search.SearchSettings.FilterIVHP}" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <Label Content="{itl:LocalizedText LC_COMMON_IV_ATTACK}" />
                                        <vu:IntegerTextBox MinValue="0" MaxValue="100" Value="{Binding Search.SearchSettings.FilterIVAttack}" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <Label Content="{itl:LocalizedText LC_COMMON_IV_DEFENSE}" />
                                        <vu:IntegerTextBox MinValue="0" MaxValue="100" Value="{Binding Search.SearchSettings.FilterIVDefense}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </vu:SpacedWrapPanel>

                        <Button Width="80" Margin="5" HorizontalAlignment="Left" 
                                Command="{Binding Search.SearchSettings.ResetCommand}" 
                                Content="{itl:LocalizedText LC_SAVESEARCH_SETTINGS_RESET}" />
                    </StackPanel>
                </Expander>

                <!-- Container Tree -->
                <GroupBox Header="{itl:LocalizedText LC_SAVESEARCH_GRP_PAL_CONTAINERS}" Grid.Row="1" Margin="0,5,0,0">
                    <TreeView x:Name="m_TreeView" 
                              ItemsSource="{Binding Search.OwnerTree.RootNodes}" 
                              SelectedItemChanged="TreeView_SelectedItemChanged" 
                              BorderBrush="{x:Null}">
                        <TreeView.Style>
                            <Style TargetType="TreeView" BasedOn="{StaticResource {x:Type TreeView}}" />
                        </TreeView.Style>
                        <TreeView.InputBindings>
                            <KeyBinding Key="Delete" 
                                        Command="{Binding Search.DeleteContainerCommand}" 
                                        CommandParameter="{Binding Search.OwnerTree.SelectedSource.Container}" />
                        </TreeView.InputBindings>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem" BasedOn="{StaticResource TreeViewItemStyle}">
                                <Setter Property="IsExpanded" Value="True" />
                                <Setter Property="IsSelected" Value="{Binding IsSelected}" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type sm:GuildTreeNodeViewModel}" ItemsSource="{Binding Children}">
                                <TextBlock Text="{Binding Label.Value}" />
                            </HierarchicalDataTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type sm:PlayerTreeNodeViewModel}" ItemsSource="{Binding Children}">
                                <TextBlock Text="{Binding Label.Value}" />
                            </HierarchicalDataTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type sm:CustomizationsTreeNodeViewModel}" ItemsSource="{Binding Children}">
                                <TextBlock Text="{Binding Label.Value}" />
                            </HierarchicalDataTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type sm:BaseTreeNodeViewModel}" ItemsSource="{Binding Children}">
                                <vu:PopupToolTipTrigger InitialShowDelay="500">
                                    <vu:PopupToolTipTrigger.Style>
                                        <Style TargetType="vu:PopupToolTipTrigger">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Coords, Converter={StaticResource VBC}}" Value="True">
                                                    <Setter Property="Cursor" Value="Hand" />
                                                    <Setter Property="ToolTipContentTemplate">
                                                        <Setter.Value>
                                                            <DataTemplate>
                                                                <vu:PopupToolTipContent>
                                                                    <vp:MapView DataContext="{Binding Coords}" Width="500" Height="500" />
                                                                </vu:PopupToolTipContent>
                                                            </DataTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </vu:PopupToolTipTrigger.Style>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Label.Value}" />
                                        <materialIcons:MaterialIcon Kind="Crosshairs" Height="12" Margin="5,0,0,0" Visibility="{Binding Coords, Converter={StaticResource VVC}}" />
                                    </StackPanel>
                                </vu:PopupToolTipTrigger>
                            </HierarchicalDataTemplate>

                            <DataTemplate DataType="{x:Type sm:PlayerPalboxContainerViewModel}">
                                <TextBlock Text="{Binding SearchedLabel.Value}" />
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type sm:PlayerPartyContainerViewModel}">
                                <TextBlock Text="{Binding SearchedLabel.Value}" />
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type sm:PlayerDimensionalPalStorageContainerViewModel}">
                                <TextBlock Text="{Binding SearchedLabel.Value}" />
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type sm:GlobalPalStorageContainerViewModel}">
                                <TextBlock Text="{Binding SearchedLabel.Value}" />
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type sm:BaseAssignedPalsTreeNodeViewModel}">
                                <TextBlock Text="{Binding SearchedLabel.Value}" />
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type sm:ViewingCageTreeNodeViewModel}">
                                <TextBlock Text="{Binding SearchedLabel.Value}" />
                            </DataTemplate>

                            <DataTemplate DataType="{x:Type sm:CustomContainerTreeNodeViewModel}">
                                <TextBlock Text="{Binding SearchedLabel.Value}">
                                    <TextBlock.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Rename"
                                                      Command="{Binding CustomContainer.RenameCommand}"
                                                      CommandParameter="{Binding Container}" />
                                            <MenuItem Header="Delete"
                                                      Command="{Binding CustomContainer.DeleteCommand}"
                                                      CommandParameter="{Binding Container}" />
                                        </ContextMenu>
                                    </TextBlock.ContextMenu>
                                </TextBlock>
                            </DataTemplate>

                            <DataTemplate DataType="{x:Type sm:NewCustomContainerTreeNodeViewModel}">
                                <TextBlock FontStyle="Italic" Text="{Binding Label.Value}" />
                            </DataTemplate>
                        </TreeView.Resources>
                    </TreeView>
                </GroupBox>
            </Grid>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" 
                          Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}" />

            <!-- Center Panel: Container Grids -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Container Grids / Pal Slots -->
                <ScrollViewer Grid.Row="0">
                    <vu:CachingContentPresenter Content="{Binding Search.OwnerTree.SelectedSource}">
                        <vu:CachingContentPresenter.ContentTemplate>
                            <DataTemplate DataType="{x:Type sm:IContainerSource}">
                                <ItemsControl ItemsSource="{Binding Container.Grids}" 
                                              HorizontalAlignment="Center" 
                                              Margin="15">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <vu:SpacedWrapPanel HorizontalSpacing="15" VerticalSpacing="15" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Visibility" Value="{Binding GridVisibility}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <ContentControl Content="{Binding}">
                                                <ContentControl.Resources>
                                                    <DataTemplate DataType="{x:Type sgvm:DefaultContainerGridViewModel}">
                                                        <sv:ContainerGridView DataContext="{Binding}"/>
                                                    </DataTemplate>
                                                    <DataTemplate DataType="{x:Type sgvm:CustomContainerGridViewModel}">
                                                        <StackPanel>
                                                            <TextBlock HorizontalAlignment="Center" 
                                                                       FontStyle="Italic" 
                                                                       Padding="0,0,0,15" 
                                                                       Text="{itl:LocalizedText LC_CUSTOM_CONTAINERS_DESCRIPTION}" />
                                                            <sv:ContainerGridView DataContext="{Binding}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ContentControl.Resources>
                                            </ContentControl>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </vu:CachingContentPresenter.ContentTemplate>
                    </vu:CachingContentPresenter>
                </ScrollViewer>

                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" 
                              Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}" />

                <!-- Selected Pal Info Dock -->
                <ContentControl Grid.Row="2"
                                DataContext="{Binding Search.OwnerTree.SelectedSource.Container.SelectedPalSlot}"
                                Content="{Binding}"
                                Visibility="{Binding Converter={StaticResource VVC}, FallbackValue=Collapsed}"
                                MaxHeight="250">
                    <ContentControl.Resources>
                        <DataTemplate DataType="{x:Type sgvm:ContainerGridCustomPalSlotViewModel}">
                            <StackPanel Background="{DynamicResource {x:Static adonisUi:Brushes.Layer3BackgroundBrush}}">
                                <GridSplitter HorizontalAlignment="Stretch" Height="5" IsEnabled="False" />
                                <StackPanel Orientation="Vertical" Margin="10,8,10,10" vu:StackPanelExtensions.Spacing="8">
                                    <sv:CustomPalEditorView DataContext="{Binding PalInstance}" />
                                    <Grid>
                                        <Button HorizontalAlignment="Left"
                                                Command="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=iv:SaveViewerWindow}, Path=ViewModel.DeleteSlotCommand}"
                                                CommandParameter="{Binding}">
                                            Delete
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type sgvm:ContainerGridPalSlotViewModel}">
                            <sv:PalInfoView DataContext="{Binding}" />
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
            </Grid>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" 
                          Background="{DynamicResource {x:Static adonisUi:Brushes.Layer1BorderBrush}}" />

            <!-- Right Panel: Container Info -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" MinHeight="150"/>
                </Grid.RowDefinitions>

                <!-- Selected Pal Info -->
                <GroupBox Header="{itl:LocalizedText LC_SAVEWINDOW_TAB_SEARCH}" Grid.Row="0">
                    <ContentControl DataContext="{Binding Search.OwnerTree.SelectedSource.Container.SelectedPalSlot}"
                                    Content="{Binding}"
                                    Visibility="{Binding Converter={StaticResource VVC}, FallbackValue=Collapsed}">
                        <ContentControl.Resources>
                            <DataTemplate DataType="{x:Type sgvm:ContainerGridPalSlotViewModel}">
                                <sv:PalInfoView DataContext="{Binding}" />
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type sgvm:ContainerGridCustomPalSlotViewModel}">
                                <StackPanel Margin="10" Background="{DynamicResource {x:Static adonisUi:Brushes.Layer3BackgroundBrush}}">
                                    <TextBlock Text="Custom Pal" FontWeight="Bold" Margin="0,0,0,5" />
                                    <TextBlock>
                                        <Run Text="Pal: " />
                                        <Run Text="{Binding PalInstance.Pal.Name.Value, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="Gender: " />
                                        <Run Text="{Binding PalInstance.Gender.Label.Value, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ContentControl.Resources>
                    </ContentControl>
                </GroupBox>

                <GridSplitter HorizontalAlignment="Stretch" Grid.Row="0" Height="5" 
                              Visibility="{Binding Search.OwnerTree.SelectedSource.Container.SelectedPalSlot, Converter={StaticResource VVC}, FallbackValue=Collapsed}" />

                <!-- Container Info -->
                <GroupBox Header="{itl:LocalizedText LC_SAVEWINDOW_TAB_DETAILS}" Grid.Row="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="5" vu:StackPanelExtensions.Spacing="5">
                            <TextBlock TextWrapping="Wrap" Visibility="{Binding Search.OwnerTree.HasValidSource, Converter={StaticResource VVC}}">
                                <Run Text="{itl:LocalizedText LC_SAVEINSPECT_CONTAINER_TYPE}" />
                                <Run Text=": " />
                                <Run Text="{Binding Search.OwnerTree.SelectedSource.Label.Value, Mode=OneWay}" />
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Visibility="{Binding Search.OwnerTree.HasValidSource, Converter={StaticResource VVC}}">
                                <Run Text="{itl:LocalizedText LC_SAVEINSPECT_CONTAINER_ID}" />
                                <Run Text=": " />
                                <Run Text="{Binding Search.OwnerTree.SelectedSource.Container.Id, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </ScrollViewer>
                </GroupBox>
            </Grid>
        </Grid>
    </DockPanel>
</adonisControls:AdonisWindow>